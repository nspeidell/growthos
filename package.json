{
  "name": "growthos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/fix-manifests.js",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute growthos-dev --local --file=./src/lib/db/migrations/0000_init.sql",
    "db:migrate:prod": "wrangler d1 execute growthos-prod --remote --file=./src/lib/db/migrations/0000_init.sql",
    "deploy": "npm run build && npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output/static --project-name=growthos --branch=production",
    "deploy:publisher": "wrangler deploy --config wrangler.publisher.toml",
    "deploy:automation-processor": "wrangler deploy --config wrangler.automation-processor.toml",
    "ship": "git add -A && git commit -m \"update\" && git push && npm run deploy"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@tailwindcss/postcss": "^4.2.4",
    "arctic": "^2.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next": "^15.4.11",
    "oslo": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.5.12",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.99.0"
  }
}
