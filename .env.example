# ═══════════════════════════════════════════
# GrowthOS Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENVIRONMENT=development

# ─── Cloudflare ───
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_D1_DATABASE_ID=

# ─── Auth: Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Security ───
SESSION_SECRET=           # 32-byte hex: openssl rand -hex 32
ENCRYPTION_KEY=           # 32-byte hex: openssl rand -hex 32

# ─── AI (Phase 2) ───
# ANTHROPIC_API_KEY=

# ─── Social OAuth (Phase 3) ───
# META_APP_ID=               # Meta (Instagram + Facebook)
# META_APP_SECRET=
# X_CLIENT_ID=               # X / Twitter
# X_CLIENT_SECRET=
# REDDIT_CLIENT_ID=          # Reddit
# REDDIT_CLIENT_SECRET=

# ─── Billing (Phase 5) ───
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=

# ─── Analytics (Phase 5) ───
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# NEXT_PUBLIC_GA4_ID=

# ─── Reunion API (Phase 6) ───
# REUNION_API_URL=           # e.g. https://api.reunion.app
# REUNION_API_KEY=
# REUNION_WEBHOOK_SECRET=

# ─── Newsletter (Phase 7C) ───
# RESEND_API_KEY=

# ─── Video Engine (Phase 8) ───
# ELEVEN_LABS_API_KEY=

# ─── Cron Jobs (Phase 9) ───
CRON_SECRET=               # Shared secret for Vercel cron Authorization header

# ─── AI Swarm (Phase 11) ───
# SWARM_MAX_CONCURRENT=5      # Max concurrent swarm agents (default: 5)
# SWARM_OVERNIGHT_HOUR=2      # UTC hour for overnight batch (default: 2)

# ─── Growth Optimization (Phase 12) ───
# GROWTH_AUTO_PROMOTE=false   # Enable autonomous mode (default: false)
# GROWTH_CONFIDENCE=0.95      # Statistical confidence threshold (default: 0.95)
